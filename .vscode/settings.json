{
    // Project default for Python: project-local .venv + pip (no conda/poetry/uv).
    "python-envs.defaultEnvManager": "ms-python.python:venv",
    "python-envs.defaultPackageManager": "ms-python.python:pip",
    "python-envs.pythonProjects": [],
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.terminal.activateEnvironment": true,
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestArgs": [
        "python/tests"
    ],

    // Use CMakePresets.json for configure/build/test
    "cmake.useCMakePresets": "always",
    "cmake.configureOnOpen": true,

    // Set default presets (change to ninja-release or ninja-relwithdebinfo as needed)
    "cmake.configurePreset": "ninja-debug",
    "cmake.buildPreset": "ninja-debug",
    "cmake.testPreset": "ninja-debug",

    // Let CMake Tools feed include paths/defines from compile_commands.json
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools"
}

